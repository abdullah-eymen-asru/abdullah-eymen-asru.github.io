---
# Bu dosya, jekyll-feed plugin'inin OTOMATİK ürettiği feed.xml'in yerine
# geçer (plugin, kökte kendi adıyla bir dosya varsa onu kullanmayı
# bırakıp bunu kullanır). Tek farkı: "yayinda: false" olan (gizli) ya da
# "date" alanı henüz gelmemiş (zamanlanmış) yazıları feed'e HİÇ
# eklemiyor — jekyll-feed'in kendi "published: false" alanı işimize
# yaramıyor çünkü o, sayfayı build'den tamamen siliyor ve gizli önizleme
# linkinin çalışmasını engelliyor.
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="tr">
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ '/' | absolute_url }}</id>
  <title type="html">{{ site.title | smartify }}</title>
  {% if site.description %}<subtitle>{{ site.description }}</subtitle>{% endif %}

  {% assign yayindaki_yazilar = site.posts | where_exp: "p", "p.yayinda != false and p.date <= site.time" %}
  {% for post in yayindaki_yazilar limit:20 %}
    <entry>
      <title type="html">{{ post.title | smartify | xml_escape }}</title>
      <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}" />
      <published>{{ post.date | date_to_xmlschema }}</published>
      <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
      <id>{{ post.id | absolute_url | xml_escape }}</id>
      <content type="html" xml:base="{{ post.url | absolute_url | xml_escape }}">{{ post.content | strip | xml_escape }}</content>
      <author>
        <name>{{ site.title | default: site.github_username }}</name>
      </author>
    </entry>
  {% endfor %}
</feed>
